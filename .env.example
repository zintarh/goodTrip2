# ── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_MAPTILER_KEY=
NEXT_PUBLIC_CELO_RPC=https://forno.celo-sepolia.celo-testnet.org
NEXT_PUBLIC_CELO_NETWORK=testnet          # set to "mainnet" for production

# ── Convex (server-side) ────────────────────────────────────────────────────
CONVEX_DEPLOY_KEY=
CONVEX_BACKEND_SIGNING_KEY=              # private key used to sign EIP-712 score vouchers
WEB3AUTH_DOMAIN=https://authjs.web3auth.io

# ── Contracts (set after `forge script script/Deploy.s.sol --broadcast`) ────
NEXT_PUBLIC_PLAYER_REGISTRY_ADDRESS=
NEXT_PUBLIC_SCORE_REGISTRY_ADDRESS=
NEXT_PUBLIC_STAKE_ESCROW_ADDRESS=
NEXT_PUBLIC_MILESTONE_REWARDS_ADDRESS=

# ── Stake tokens (per network — required to create/join a staked game) ───────
NEXT_PUBLIC_GD_TOKEN_ADDRESS=             # GoodDollar has no testnet deployment; mainnet only
NEXT_PUBLIC_USDT_TOKEN_ADDRESS=

# Same treasury address StakeEscrow pays its rake to — also where hint/streak-
# freeze G$ payments are sent, so Convex can verify them on-chain.
NEXT_PUBLIC_TREASURY_ADDRESS=             # frontend copy, used to build the payment tx
TREASURY_ADDRESS=                        # Convex copy, same value, used to verify payments

# Convex backend also needs ScoreRegistry address + chain to sign vouchers
SCORE_REGISTRY_ADDRESS=                  # same value as NEXT_PUBLIC_SCORE_REGISTRY_ADDRESS
STAKE_ESCROW_ADDRESS=                    # same value as NEXT_PUBLIC_STAKE_ESCROW_ADDRESS — used to sign settlement vouchers
CELO_CHAIN_ID=11142220                   # 11142220 = Celo Sepolia testnet, 42220 = mainnet
CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org  # Convex copy of NEXT_PUBLIC_CELO_RPC, used to verify payments
GD_TOKEN_ADDRESS=                        # Convex copy of NEXT_PUBLIC_GD_TOKEN_ADDRESS, used to verify hint/streak payments
CONVEX_SETTLEMENT_SIGNING_KEY=           # separate key from CONVEX_BACKEND_SIGNING_KEY — signs StakeEscrow settlement (real funds), not per-round scores

# ── Goldsky ─────────────────────────────────────────────────────────────────
GOLDSKY_API_KEY=
NEXT_PUBLIC_SUBGRAPH_URL=
